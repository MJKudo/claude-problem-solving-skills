{
  // スキル本体・工程テンプレート・レビュープロンプト用のリント設定。
  // これらの文書は「コピーして使う文書のひな形」を本文中に含むため、
  // 通常の記事向けルールのうち次の2つだけ無効化する。
  "config": {
    "default": true,
    "MD013": false,
    "MD033": false,
    "MD041": false,
    "MD024": { "siblings_only": true },
    // 工程テンプレートは1ファイル内に複数の成果物ひな形(それぞれが # 見出しを持つ)を並べる
    "MD025": false,
    // ひな形では見出しの直下に記入欄の説明を置く書式を採る
    "MD022": false
  }
}
